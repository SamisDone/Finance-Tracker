# Environment Variables for FinPulse
# Copy this file to .env and configure as needed

# Database Type: 'sqlite' (default, portable) or 'mysql'
DB_TYPE=sqlite

# SQLite Configuration (used when DB_TYPE=sqlite)
# Path to SQLite database file (relative to project root)
DB_PATH=finance_tracker.db

# MySQL Configuration (used when DB_TYPE=mysql)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=finance_tracker_db
